# Copy to .env.docker (gitignored) before: compose -f docker-compose.prod.yml up -d
#
#   cp .env.docker.example .env.docker
#   # edit APP_KEY + APP_URL

APP_NAME=LeadGeeks IT
APP_ENV=production
APP_DEBUG=false
APP_URL=https://leadgeeks-ticket.iqbalalhabib.my.id

# Generate once and keep stable across deploys (sessions/cookies):
#   php -r "echo 'base64:'.base64_encode(random_bytes(32)), PHP_EOL;"
APP_KEY=

SEED_ON_START=true
LOG_CHANNEL=stderr
LOG_LEVEL=warning
TZ=Asia/Jakarta

# Optional overrides for compose interpolation
# IMAGE_TAG=latest
# HOST_PORT=3002
